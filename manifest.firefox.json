{
  "manifest_version": 3,
  "name": "Rinaudo Capital",
  "version": "0.4.0",
  "description": "Earn tickets for liking and commenting on Mizkif's posts, and get pinged when he goes live or posts.",
  "browser_specific_settings": {
    "gecko": {
      "id": "rinaudo-capital@jsolutions.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": { "required": ["none"], "optional": ["technicalAndInteraction"] }
    }
  },
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "host_permissions": ["https://rinaudoglobal.com/*", "https://x.com/*", "https://twitter.com/*", "https://s2.jsolutions.dev/*", "https://kick.com/*"],
  "background": { "scripts": ["config.js", "background.js"] },
  "action": { "default_popup": "popup/popup.html", "default_title": "Rinaudo Capital" },
  "icons": { "128": "icons/icon128.png" },
  "content_scripts": [
    {
      "matches": ["https://kick.com/mizkif*"],
      "js": ["config.js", "content/kick.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*/status/*", "https://twitter.com/*/status/*"],
      "js": ["config.js", "content/x.js"],
      "run_at": "document_idle"
    }
  ]
}
