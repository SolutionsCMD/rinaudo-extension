{
  "manifest_version": 3,
  "name": "Rinaudo Capital",
  "version": "1.0.16",
  "description": "Earn tickets for liking, commenting on, and watching Mizkif's posts and videos, and get pinged when he goes live or posts.",
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "host_permissions": ["https://rinaudoglobal.com/*", "https://s2.jsolutions.dev/*", "https://kick.com/*", "https://www.youtube.com/*", "https://www.tiktok.com/*", "https://www.instagram.com/*", "https://x.com/*", "https://twitter.com/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup/popup.html", "default_title": "Rinaudo Capital" },
  "icons": { "128": "icons/icon128.png" },
  "content_scripts": [
    {
      "matches": ["https://kick.com/mizkif*"],
      "js": ["config.js", "content/widget-frame.js", "content/kick.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["config.js", "content/widget-frame.js", "content/engage-core.js", "content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["config.js", "content/widget-frame.js", "content/engage-core.js", "content/tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["config.js", "content/widget-frame.js", "content/engage-core.js", "content/instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["config.js", "content/widget-frame.js", "content/engage-core.js", "content/x.js"],
      "run_at": "document_idle"
    }
  ]
}
