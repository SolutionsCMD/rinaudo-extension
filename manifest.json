{
  "manifest_version": 3,
  "name": "Rinaudo Capital — Live Votes",
  "version": "0.1.0",
  "description": "Vote on Mizkif's stock picks live, and get pinged the moment a poll opens.",
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "host_permissions": ["https://kick.com/*", "https://rinaudoglobal.com/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup/popup.html", "default_title": "Rinaudo Capital" },
  "icons": { "128": "icons/icon128.png" },
  "content_scripts": [
    {
      "matches": ["https://kick.com/mizkif*"],
      "js": ["config.js", "content/kick.js"],
      "css": ["content/card.css"],
      "run_at": "document_idle"
    }
  ]
}
